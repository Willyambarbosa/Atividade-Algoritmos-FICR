# Questão 8. Escreva um algoritmo que recebe o valor do salário fixo e o total de vendas efetuadas por um vendedor.
# Sabendo que ele ganha 15% de comissão, informar o salário fixo e o salário no final do mês.

# Entrada de dados
salario_fixo = float(input("Digite o salário fixo: R$ "))
total_vendas = float(input("Digite o total de vendas no mês: R$ "))

# Cálculo da comissão (15%)
comissao = total_vendas * 0.15
salario_final = salario_fixo + comissao

# Exibição
print("Salário Fixo: R$", salario_fixo)
print("Salário Final (com comissão): R$", salario_final)
