# Questão 4. Fazer um algoritmo que calcule e mostre: a) A soma entre dois números; b) O produto entre eles e c) O quociente entre eles.

# Entrada de dados (usando float para permitir números com vírgula)
n1 = float(input("Digite o primeiro número: "))
n2 = float(input("Digite o segundo número: "))

# Cálculos
soma = n1 + n2
produto = n1 * n2
quociente = n1 / n2

# Exibição
print("A soma é:", soma)
print("O produto é:", produto)
print("O quociente é:", quociente)
